LLM_API_KEY="your-llm-api-key-here"
LLM_BASE_URL="https://your-llm-endpoint.example.com/v2"
LLM_MODEL="your-default-model-name"
PADDLEOCRVL_MODEL_DIR="models/paddleocrvl1_5"
PADDLEOCRVL_VERSION="1.5"               # 1.5 (default) or 1.0
KNOWMAT2_TRIM_REFERENCES_SECTION="false"      # Default false: keep text after References; true: truncate as per old behavior
LANGCHAIN_API_KEY="your-langsmith-api-key"  # optional
LANGCHAIN_TRACING_V2="false"               # optional

#
# Copy this file to `.env` and fill in real values locally.
# IMPORTANT: Never commit the real `.env` file or any real API keys to git.
#
