      "Composition_Info": {
        "Role": "Target",
        "Alloy_Name_Raw": "MgAlB4w/AA2024",
        "Nominal_Composition": {
          "Composition_Type": "wt%",
          "Elements_Normalized": {
            "Al": 98.5,
            "other": 1.5
          }
        },
        "Measured_Composition": null,
        "Note": "The nominal composition is based on the matrix alloy AA2024 with 1.5 wt.% B addition. B is assumed to fully react to form MgAlB4, consuming Al and Mg from the matrix."
      },
      "Process_Info": {
        "Process_Category": "Additive Manufacturing + Post-Processing",
        "Process_Text": {
          "original": "Fabricated via LPBF in an EP-M260 machine under argon. Optimized parameters: laser power 300 W, scanning speed 1100 mm/s, hatching space 100μm, layer thickness 40μm. Substrate preheated to 45°C. The as-built sample was then subjected to solution treatment (ST) at 505°C for 1 h, followed by water quenching. Subsequently, naturally aged at room temperature (25°C) for 30 days.",
          "simplified": "LPBF + Solution treated at 505°C/1h + Water quenched + Naturally aged for 30 days."
        },
        "Equipment": "EP-M260 LPBF machine",
        "Key_Params": {
          "Laser_Power_W": 300.0,
          "Scanning_Speed_mm_s": 1100.0,
          "Hatch_Spacing_um": 100.0,
          "Layer_Thickness_um": 40.0,
          "Build_Plate_Temperature_K": 318.15,
          "Solution_Temperature_K": 778.15,
          "Solution_Time_h": 1.0,
          "Cooling_Medium": "Water",
          "Protective_Atmosphere": "Argon"
        }
      },
      "Microstructure_Info": {
        "Microstructure_Text": {
          "original": "Refined equiaxed grain structure with an average grain size of ~1.5μm. Dense, uniformly dispersed MgAlB4 nanowhiskers with diameters of 5-15 nm and aspect ratios >20 are present. Partial bright contrast phase adjacent to the whiskers corresponding to θ (Al2Cu) phase.",
          "simplified": "Refined equiaxed grains (~1.5 μm). Dense MgAlB4 nanowhiskers (diameter 5-15 nm) and θ (Al2Cu) precipitates."
        },
        "Main_Phase": "FCC",
        "Precipitates": [
          {
            "Phase_Type": "MgAlB4",
            "Volume_Fraction_pct": null
          },
          {
            "Phase_Type": "Al2Cu",
