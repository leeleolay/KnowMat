      },
      "Process_Info": {
        "Process_Category": "AM_LPBF",
        "Process_Text": {
          "original": "Laser Powder Bed Fusion (LPBF) using EP-M150 Metal 3D Printer (Hangzhou Eplus 3d Tech, China); alloy powders mixed with 2 wt% TiB2 nanoparticles by mechanical stirring in anhydrous ethanol at 1000 rpm for 3 h, dried in vacuum at 60 C for 48 h; process under argon atmosphere; laser power 150 W; scan speed 1000 mm/s; scan spacing 0.08 mm; layer thickness 0.02 mm; build platform preheated to 200 C",
          "simplified": "LPBF of FVS0812 alloy with 2 wt% TiB2 nanoparticles; 150 W, 1000 mm/s, 0.08 mm hatch, 0.02 mm layer, argon atmosphere, 200 C build plate"
        },
        "Equipment": "EP-M150 Metal 3D Printer (Hangzhou Eplus 3d Tech, China)",
        "Key_Params": {
          "Laser_Power_W": 150,
          "Scanning_Speed_mm_s": 1000,
          "Hatch_Spacing_mm": 0.08,
          "Layer_Thickness_mm": 0.02,
          "Build_Plate_Temperature_C": 200,
          "Protective_Atmosphere": "Argon",
          "TiB2_Content_wt_pct": 2,
          "Powder_Mixing_RPM": 1000,
          "Powder_Mixing_Time_h": 3,
          "Powder_Size_avg_um": 34.3,
          "Powder_Size_Range_um": "15-53"
        }
      },
      "Microstructure_Info": {
        "Microstructure_Text": {
          "original": "Dendritic cell boundaries interweave through alpha-Al cells forming continuous network approximately 14 nm in width; alpha-Al cells have average diameter approximately 67 nm; Fe and Si enriched at cell boundaries forming amorphous structure (confirmed by TEM FFT patterns showing disordered atomic arrangement and absence of periodic diffraction spots); approximately 38% amorphous boundaries in fusion zone; TiV nucleation cores approximately 50 nm enriched with Ti and V; 3D-APT shows spatial continuity of Fe- and Si-enriched amorphous boundaries interwoven with Al-rich alpha-Al cells; compositional transition zone approximately 2 nm between cells and boundaries; fusion zone approximately 80% of microstructure, heat-affected zone near pool boundary",
          "simplified": "Continuous 3D nanoscale crystalline-amorphous interpenetrating network; alpha-Al cells (67 nm) separated by amorphous cell boundaries (14 nm wide, ~38 vol%); TiV nanocrystalline nucleation cores"
        },
