      },
      "Process_Info": {
        "Process_Category": "Electron beam melting (EBM)",
        "Process_Text": {
          "original": "Rectangular rods of 44-4 alloy with dimensions of 10×10×15mm and 10×10×30mm were fabricated using an Arcam Q10 EBM system at an accelerating voltage of 60kV and a preheating temperature of 1333K. The layer thickness for each fed powder layer was 90μm and the building direction was parallel to the longitudinal direction of the rods. The energy density (ED) was changed from 0.9 J/mm² to 12.5 J/mm² by controlling beam current I from 6mA to 28mA and scanning speed v from 800 mm/s to 5000 mm/s. For R1 (high ED), ED = 4.0 J/mm².",
          "simplified": "EBM (Arcam Q10), High Energy Density (HED) condition. Energy density 4.0 J/mm²."
        },
        "Equipment": "Arcam Q10",
        "Key_Params": {
          "Energy_Density_J_mm2": 4.0,
          "Build_Plate_Temperature_K": 1333.15
        }
      },
      "Microstructure_Info": {
        "Microstructure_Text": {
          "original": "The high ED rod has a uniform α2/β/γ mixed structure composed of two regions: the α2/γ lamellar region and the β/γ dual phase region (hereafter called a high energy density (HED) microstructure). The volume fraction of the β and γ phases in the β/γ dual phase region is approximately 50%. The average lamellar spacing (λ) of the lamellae in the HED microstructure is 62.1 nm. The β phase has an ordered B2 structure (superlattice 001 spot in SAED).",
          "simplified": "HED microstructure: uniform α2/β/γ mixed structure with α2/γ lamellar regions and β/γ dual-phase regions. Lamellar spacing 62.1 nm. In β/γ dual-phase region, β and γ each ~50 vol%. β phase is ordered B2."
        },
        "Main_Phase": "Gamma (γ) + Alpha2 (α2)",
        "Precipitates": [
          {
            "Phase_Type": "Beta (B2)",
            "Volume_Fraction_pct": null
          }
        ],
